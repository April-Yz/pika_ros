<launch>

    <arg name="project" default="data_tools"/>
    <arg name="useService" default="true"/>
    <arg name="episodeIndex" default="0"/>
    <arg name="datasetDir" default="/home/agilex/data"/>
    <arg name="instructions" default="[null]"/>
    <arg name="hz" default="-1"/>
    <arg name="timeout" default="2"/>
    <arg name="cropTime" default="1"/>

    <arg name="d435_name" default="externalD435"/>
    <arg name="d435_frame" default="d435_color_optical_frame"/>
    <arg name="d435_color_info_topic" default="/d435/color/camera_info"/>

    <rosparam subst_value="true">
      dataInfo:
        camera:
          color:
            names: ['pikaGripperDepthCamera_l', 'pikaGripperDepthCamera_r', '$(arg d435_name)']
            parentFrames: ['gripper/camera_l_link', 'gripper/camera_r_link', '$(arg d435_frame)']
            topics: ['/buffered_capture/gripper/camera_l/color/image_raw', '/buffered_capture/gripper/camera_r/color/image_raw', '/buffered_capture/camera/color/image_raw']
            configTopics: ['/gripper/camera_l/color/camera_info', '/gripper/camera_r/color/camera_info', '$(arg d435_color_info_topic)']
          depth:
            names: ['pikaGripperDepthCamera_l', 'pikaGripperDepthCamera_r']
            parentFrames: ['gripper/camera_l_link', 'gripper/camera_r_link']
            topics: ['/buffered_capture/gripper/camera_l/aligned_depth_to_color/image_raw', '/buffered_capture/gripper/camera_r/aligned_depth_to_color/image_raw']
            configTopics: ['/gripper/camera_l/aligned_depth_to_color/camera_info', '/gripper/camera_r/aligned_depth_to_color/camera_info']
          pointCloud:
            names: []
            parentFrames: []
            topics: []
            configTopics: []
            maxDistances: []
            downSizes: []
        arm:
          jointState:
            names: ['masterLeft', 'masterRight', 'puppetLeft', 'puppetRight']
            topics: ['/buffered_capture/joint_states_gripper_l', '/buffered_capture/joint_states_gripper_r', '/buffered_capture/joint_states_single_gripper_l', '/buffered_capture/joint_states_single_gripper_r']
          endPose:
            names: ['masterLeft', 'masterRight', 'puppetLeft', 'puppetRight']
            topics: ['/buffered_capture/piper_IK_l/receive_end_pose_orient', '/buffered_capture/piper_IK_r/receive_end_pose_orient', '/buffered_capture/piper_FK_l/urdf_end_pose_orient', '/buffered_capture/piper_FK_r/urdf_end_pose_orient']
            orients: [true, true, true, true]
        localization:
          pose:
            names: ['pika_l', 'pika_r']
            topics: ['/buffered_capture/pika_pose_l', '/buffered_capture/pika_pose_r']
        gripper:
          encoder:
            names: ['pikaSensor_l', 'pikaSensor_r', 'pikaGripper_l', 'pikaGripper_r']
            topics: ['/buffered_capture/sensor/gripper_l/data', '/buffered_capture/sensor/gripper_r/data', '/buffered_capture/gripper/gripper_l/data', '/buffered_capture/gripper/gripper_r/data']
        imu:
          9axis:
            names: []
            topics: []
        lidar:
          pointCloud:
            names: []
            topics: []
            xDistanceUppers: []
            xDistanceLowers: []
            yDistanceUppers: []
            yDistanceLowers: []
            zDistanceUppers: []
            zDistanceLowers: []
            downSizes: []
        robotBase:
          vel:
            names: []
            topics: []
        lift:
          motor:
            names: []
            topics: []
            pubTopics: []
        tf:
          transform:
            parentFrames: []
            childFrames: []
    </rosparam>

    <param name="useService" value="$(arg useService)"/>
    <param name="episodeIndex" value="$(arg episodeIndex)"/>
    <param name="datasetDir" value="$(arg datasetDir)"/>
    <param name="instructions" value="$(arg instructions)"/>
    <param name="hz" value="$(arg hz)"/>
    <param name="timeout" value="$(arg timeout)"/>
    <param name="cropTime" value="$(arg cropTime)"/>

    <node pkg="$(arg project)" type="$(arg project)_dataCapture" name="$(arg project)_dataCapture" output="screen" respawn="true" respawn_delay="2"/>
</launch>
